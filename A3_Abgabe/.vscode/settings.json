{
  "latex-workshop.latex.autoBuild.run": "onSave",
  "latex-workshop.latex.autoBuild.interval": 1000,
  "latex-workshop.latex.autoBuild.ignore": ["**/*.fls", "**/*.log", "**/*.aux"],
  "latex-workshop.latex.recipes": [
    {
      "name": "latexmk (shell-escape)",
      "tools": ["latexmk-shell-escape"]
    }
  ],
  "latex-workshop.latex.tools": [
    {
      "name": "latexmk-shell-escape",
      "command": "latexmk",
      "args": ["-pdf", "-interaction=nonstopmode", "-synctex=1", "-shell-escape", "%DOC%"],
      "env": {}
    }
  ]
}
